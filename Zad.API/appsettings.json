{
  "ConnectionStrings": {
    "DefaultConnection": "Server=localhost,1433;Database=ZadDb;User Id=sa;Password=Your_password123!;TrustServerCertificate=True;"
  },
  "AiService": {
    "BaseUrl": "",
    "TimeoutSeconds": 30
  },
  "Jwt": {
    "Issuer": "zad-api",
    "Audience": "zad-mobile-app",
    "ExpirationMinutes": 1440,
    "Secret": "ZadSecretZadSecretZadSecretZadSecret"
  },
  "Cors": {
    "AllowedOrigins": [],
    "AllowedMethods": [
      "GET",
      "POST",
      "DELETE"
    ],
    "AllowedHeaders": [
      "Authorization",
      "Content-Type"
    ]
  },
  "Serilog": {
    "Using": [
      "Serilog.Sinks.Console",
      "Serilog.Sinks.File"
    ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "System": "Warning"
      }
    },
    "Enrich": [
      "FromLogContext"
    ],
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {Message:lj} {Properties:j}{NewLine}{Exception}"
        }
      },
      {
        "Name": "File",
        "Args": {
          "path": "logs/log-.txt",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 14,
          "shared": true,
          "outputTemplate": "[{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} {Level:u3}] {Message:lj} {Properties:j}{NewLine}{Exception}"
        }
      }
    ]
  },
  "Swagger": {
    "Enabled": true
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning",
      "Microsoft.AspNetCore": "Warning",
      "System": "Warning"
    }
  },
  "AllowedHosts": "*"
}
